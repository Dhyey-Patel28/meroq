# Optional news providers. Keep real keys in .env only.
# Meroq does not ship or store API keys in the repository.
FINNHUB_API_KEY=
NEWSAPI_API_KEY=

# Optional Hugging Face cache behavior.
# HF_HOME=./hf_cache
# TRANSFORMERS_OFFLINE=0

# Optional API CORS override for local/frontend development.
# Example: MEROQ_API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MEROQ_API_ALLOWED_ORIGINS=
